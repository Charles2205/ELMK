# Resend (https://resend.com) — used by src/lib/actions.ts to email
# contact-form and newsletter-signup notifications.

# API key from the Resend dashboard.
RESEND_API_KEY=

# Inbox that receives contact/newsletter notifications.
CONTACT_TO_EMAIL=info@locomotionfoundation.org 

# Sender address on a domain verified in Resend (e.g. noreply@locomotionfoundation.org).
CONTACT_FROM_EMAIL=
